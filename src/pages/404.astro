---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import PageFooter from '../components/PageFooter.astro';
---
<BaseLayout
  title="Not in this volume — CIRWEL Systems"
  description="The page you requested is not indexed on cirwel.org. Return to the thesis or read the ecosystem dossier."
>
  <PageHeader currentPath="/404" />

  <main class="px-6 lg:px-12 max-w-screen-xl mx-auto">

    <section class="pt-24 pb-32 lg:pt-40 lg:pb-48 grid grid-cols-12 gap-6">
      <div class="col-span-12 lg:col-span-9">
        <p class="label text-oxblood mb-8">— A page that is not in this volume</p>
        <h1 class="display text-5xl md:text-7xl lg:text-8xl mb-10">
          404.<br/>
          <span class="italic">Not</span> indexed.
        </h1>
        <p class="text-lg md:text-xl leading-relaxed text-stone max-w-prose mb-10">
          The address you requested is not a page on this site. The link may
          be stale, a typo, or pointing at a section that was retired in an
          earlier edition.
        </p>

        <hr class="hairline mb-10 max-w-prose"/>

        <ul class="space-y-5 text-lg max-w-prose">
          <li class="grid grid-cols-12 gap-4 items-baseline">
            <span class="col-span-12 md:col-span-3 label text-stone">Return</span>
            <span class="col-span-12 md:col-span-9">
              to the thesis at <a href="/" class="font-medium">cirwel.org</a>.
            </span>
          </li>
          <li class="grid grid-cols-12 gap-4 items-baseline">
            <span class="col-span-12 md:col-span-3 label text-stone">Read deeper</span>
            <span class="col-span-12 md:col-span-9">
              the <a href="/ecosystem" class="font-medium">ecosystem dossier</a>.
            </span>
          </li>
          <li class="grid grid-cols-12 gap-4 items-baseline">
            <span class="col-span-12 md:col-span-3 label text-stone">Report</span>
            <span class="col-span-12 md:col-span-9">
              the broken link to
              <a href="mailto:founder@cirwel.org" class="font-mono text-base">founder@cirwel.org</a>.
            </span>
          </li>
        </ul>
      </div>
    </section>

    <hr class="hairline"/>

  </main>

  <PageFooter />
</BaseLayout>
