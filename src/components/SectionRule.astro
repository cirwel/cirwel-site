---
/*
  SectionRule — an ornamented section break.

  Replaces a bare <hr class="hairline"/> with the journal-cover register
  already used by the masthead and publisher's mark: a hairline rule on
  each side of a centered engraved fleuron. Gives the long single-column
  pages a printed-page rhythm so the reader meets an ornament, not another
  wall of text, at every section seam.
*/
import Ornament from './Ornament.astro';
interface Props {
  /** Top/bottom margin utility classes, e.g. "my-2". Defaults to none so callers control spacing. */
  class?: string;
}
const { class: cls = '' } = Astro.props;
---
<div class:list={["flex items-center justify-center gap-5", cls]} role="presentation">
  <hr class="hairline flex-1" />
  <Ornament size="rule" class="shrink-0 opacity-90" />
  <hr class="hairline flex-1" />
</div>
