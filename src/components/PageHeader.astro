---
interface Props {
  /**
   * Pathname of the current page, used to (a) emit cross-page hash links from
   * non-home pages and (b) highlight the active section in the nav.
   * Examples: '/', '/ecosystem'.
   */
  currentPath: string;
}
const { currentPath } = Astro.props;
const onHome = currentPath === '/';
const thesisHref  = onHome ? '#thesis'  : '/#thesis';
const contactHref = onHome ? '#contact' : '/#contact';
const isEcosystem = currentPath === '/ecosystem';
---
<!-- Masthead — journal-cover register -->
<div class="max-w-screen-xl mx-auto px-6 lg:px-12 pt-6 flex items-center justify-center gap-4">
  <hr class="hairline flex-1 max-w-[140px]" />
  <p class="label text-stone text-[0.62rem] tracking-[0.28em] whitespace-nowrap">
    Independent Research &middot; Est. 2025
  </p>
  <hr class="hairline flex-1 max-w-[140px]" />
</div>

<!--
  Header: row layout at sm+ (wordmark left, nav right).
  At <sm: column layout — wordmark centered on its own line,
  full six-link nav wrapping below, also centered. Mobile readers
  get every nav option, not a reduced subset.
-->
<header class="px-6 lg:px-12 pt-5 pb-4 max-w-screen-xl mx-auto flex flex-col items-center gap-3 sm:flex-row sm:items-center sm:justify-between sm:gap-4">
  <a href="/" class="no-underline shrink-0 flex items-center gap-2.5">
    <img src="/mark-c-illuminated.svg" alt=""
         class="block w-[30px] h-[30px] sm:w-[36px] sm:h-[36px]" />
    <span class="display smcp text-lg sm:text-xl font-medium">CIRWEL Systems</span>
  </a>
  <nav aria-label="Primary"
       class="flex flex-wrap items-center justify-center sm:justify-end gap-x-5 gap-y-2 sm:gap-5 md:gap-7 label text-stone">
    <a href={thesisHref}
       class="no-underline hover:text-oxblood transition-colors">
      Thesis
    </a>
    <a href="/ecosystem"
       class:list={[
         "no-underline transition-colors",
         isEcosystem ? "text-oxblood" : "hover:text-oxblood",
       ]}>
      Ecosystem
    </a>
    <a href="https://doi.org/10.5281/zenodo.19647159"
       class="no-underline hover:text-oxblood transition-colors">
      Paper
    </a>
    <a href="https://github.com/cirwel/unitares"
       class="no-underline hover:text-oxblood transition-colors">
      Server
    </a>
    <a href="https://github.com/cirwel/unitares-governance-plugin"
       class="no-underline hover:text-oxblood transition-colors">
      Plugin
    </a>
    <a href={contactHref}
       class="no-underline hover:text-oxblood transition-colors">
      Contact
    </a>
  </nav>
</header>
