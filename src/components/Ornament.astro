---
/*
  Ornament — an engraved printer's flower (fleuron).

  The decorative vocabulary of an 18th-c book: a small central hex device
  (the publisher's mark, in miniature) flanked by two mirrored leaf-scrolls,
  cut with the same hand-roughness filter as logo-engraved.svg. Used three
  ways across the site:

    • size="rule"   — the central piece of a SectionRule divider
    • size="floret" — a small marginal ornament in a section gutter
    • size="mark"   — a tiny inline glyph beside a running label

  Pure decoration: marked aria-hidden so screen readers skip it. A unique
  filter id per instance keeps the turbulence seeds from colliding when
  several ornaments share a page.
*/
interface Props {
  /** Visual scale. rule (divider centerpiece) · floret (margin) · mark (inline glyph). */
  size?: 'rule' | 'floret' | 'mark';
  class?: string;
}
const { size = 'rule', class: cls = '' } = Astro.props;

// Render width in px per role; the viewBox is fixed so the art scales cleanly.
const px = { rule: 92, floret: 64, mark: 16 }[size];

// Per-instance filter id — avoids cross-contamination of <filter> defs when
// many ornaments coexist (same reason the figure SVGs each name their own).
const fid = 'orn-' + Math.random().toString(36).slice(2, 8);
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 96 28"
  width={px}
  height={(px * 28) / 96}
  class={cls}
  aria-hidden="true"
  focusable="false"
>
  <defs>
    <filter id={fid} x="-6%" y="-6%" width="112%" height="112%">
      <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" seed="11" result="n" />
      <feDisplacementMap in="SourceGraphic" in2="n" scale="0.45" />
    </filter>

    <!-- Right-hand leaf-scroll, drawn once; the left side is a mirror via <use>. -->
    <g id={fid + '-scroll'}>
      <path
        d="M 55 14 C 63 14, 66 8, 73 9 C 80 10, 83 16, 78 19 C 74.5 21.3, 70.5 18.7, 72 15"
        fill="none" stroke="#7A1F1F" stroke-width="1.1" stroke-linecap="round" />
      <!-- bud springing off the stem -->
      <path d="M 62 12.4 C 62 8.6, 65 7, 68.5 7.8"
            fill="none" stroke="#7A1F1F" stroke-width="0.9" stroke-linecap="round" />
      <circle cx="69.2" cy="7.6" r="1.15" fill="#7A1F1F" />
      <!-- terminal curl dot -->
      <circle cx="74.2" cy="16.2" r="1.3" fill="#7A1F1F" />
    </g>
  </defs>

  <g filter={`url(#${fid})`}>
    <!-- Central hex device (flat-top, r≈7) with seated dot -->
    <polygon
      points="44.5,7.94 51.5,7.94 55,14 51.5,20.06 44.5,20.06 41,14"
      fill="none" stroke="#7A1F1F" stroke-width="1.2" stroke-linejoin="round" />
    <circle cx="48" cy="14" r="1.7" fill="#7A1F1F" />

    <!-- Right scroll, then its mirror about x=48 -->
    <use href={`#${fid}-scroll`} />
    <use href={`#${fid}-scroll`} transform="matrix(-1 0 0 1 96 0)" />
  </g>
</svg>
