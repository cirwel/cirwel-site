---
/*
  Tailpiece — an engraved cul-de-lampe.

  The closing vignette an 18th-c book sets at the end of a chapter or volume:
  a symmetric spray of leaf-scrolls around the hex device, tapering to a
  pendant point. Grander than the fleuron divider; used once, just above the
  colophon, to end the page. Decorative; aria-hidden.
*/
interface Props {
  class?: string;
}
const { class: cls = '' } = Astro.props;
const fid = 'tail-' + Math.random().toString(36).slice(2, 8);
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 240 96"
  width="232"
  height="93"
  class={cls}
  aria-hidden="true"
  focusable="false"
>
  <defs>
    <filter id={fid} x="-4%" y="-4%" width="108%" height="108%">
      <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" seed="17" result="n" />
      <feDisplacementMap in="SourceGraphic" in2="n" scale="0.5" />
    </filter>
    <!-- Right-hand scroll spray; left side is its mirror. -->
    <g id={fid + '-spray'}>
      <!-- upper arching scroll -->
      <path d="M 130 26 C 158 20, 182 22, 196 34 C 204 41, 202 50, 194 51 C 187 52, 184 45, 189 41"
            fill="none" stroke="#7A1F1F" stroke-width="1.1" stroke-linecap="round" />
      <!-- leaf bud off the upper scroll -->
      <path d="M 158 22.5 C 160 15, 167 12, 174 14" fill="none" stroke="#7A1F1F" stroke-width="0.9" stroke-linecap="round" />
      <circle cx="174.6" cy="13.8" r="1.3" fill="#7A1F1F" />
      <!-- lower short scroll -->
      <path d="M 130 32 C 150 34, 164 40, 168 52 C 170 58, 165 62, 160 59"
            fill="none" stroke="#7A1F1F" stroke-width="0.9" stroke-linecap="round" />
      <circle cx="195" cy="48.5" r="1.3" fill="#7A1F1F" />
    </g>
  </defs>

  <g filter={`url(#${fid})`}>
    <!-- Crown swag above the device -->
    <g stroke="#7A1F1F" stroke-width="0.8" fill="none">
      <path d="M 104 22 Q 120 12, 136 22" />
      <circle cx="120" cy="19.5" r="1.7" fill="#7A1F1F" />
      <line x1="111" y1="22" x2="105" y2="14" />
      <line x1="129" y1="22" x2="135" y2="14" />
    </g>

    <!-- Central hex device -->
    <polygon points="-9,-15.6 9,-15.6 18,0 9,15.6 -9,15.6 -18,0" transform="translate(120,30)"
             fill="none" stroke="#7A1F1F" stroke-width="1.3" />
    <polygon points="-3.2,-5.5 3.2,-5.5 6.4,0 3.2,5.5 -3.2,5.5 -6.4,0" transform="translate(120,30)"
             fill="#7A1F1F" />
    <circle cx="120" cy="30" r="1.7" fill="#F5F1E8" />

    <!-- Side sprays -->
    <use href={`#${fid}-spray`} />
    <use href={`#${fid}-spray`} transform="matrix(-1 0 0 1 240 0)" />

    <!-- Pendant, tapering to a point -->
    <g stroke="#7A1F1F" fill="#7A1F1F">
      <line x1="120" y1="46" x2="120" y2="58" stroke-width="0.9" />
      <polygon points="120,57 124,64 120,71 116,64" stroke="none" />
      <line x1="120" y1="71" x2="120" y2="80" stroke-width="0.7" />
      <circle cx="120" cy="83" r="1.7" stroke="none" />
      <!-- tiny leaf pair at the lozenge -->
      <path d="M 116 62 C 110 60, 107 63, 108 67" fill="none" stroke-width="0.8" />
      <path d="M 124 62 C 130 60, 133 63, 132 67" fill="none" stroke-width="0.8" />
    </g>
  </g>
</svg>
